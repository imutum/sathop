# ── image（默认指向 imutum 官方镜像；自部署可改为你的 GitHub 用户名或组织名）──
SATHOP_IMAGE=ghcr.io/imutum/sathop
SATHOP_TAG=latest

# ── required ──
SATHOP_WORKER_ID=worker-1
SATHOP_PUBLIC_URL=http://worker-1.example.com:9000

# Single connection string carrying both orch URL and token (Redis-style).
#   sathop://TOKEN@host:port    → plain HTTP
#   sathops://TOKEN@host:port   → HTTPS (use when orch is fronted by a reverse proxy)
SATHOP_URL=sathop://change-me@orchestrator.example.com:8000

# Alternative: split form (used as fallback only if SATHOP_URL is unset).
# SATHOP_ORCH_URL=http://orchestrator.example.com:8000
# SATHOP_TOKEN=change-me

# ── capacity / paths ──
SATHOP_CAPACITY=20
SATHOP_WORK_ROOT=./data/work
SATHOP_BUNDLE_CACHE=./data/bundles
SATHOP_VENV_CACHE=./data/venvs
SATHOP_SHARED_CACHE=./data/shared
SATHOP_STORAGE_ROOT=./data/storage
SATHOP_STORAGE_PORT=9000
SATHOP_HEARTBEAT=15
SATHOP_LEASE_POLL=10

# ── Credentials ──
# Not set here. Credentials ride on each lease from the orchestrator — the
# user specifies them per-batch at creation time (BatchCreate.credentials).

# ── Backpressure (optional; sensible defaults) ──
SATHOP_DISK_PAUSE_PCT=0.85
SATHOP_DISK_RESUME_PCT=0.70
SATHOP_BACKPRESSURE_INTERVAL=10

# ── aria2c RPC (optional; empty = fall back to httpx) ──
SATHOP_ARIA2_RPC=
SATHOP_ARIA2_SECRET=

# ── MinIO (optional; empty = fall back to local FS + static HTTP server) ──
# Endpoint is derived from SATHOP_PUBLIC_URL (presigned URLs need the public host).
SATHOP_MINIO_ACCESS_KEY=
SATHOP_MINIO_SECRET_KEY=
SATHOP_MINIO_BUCKET=sathop
