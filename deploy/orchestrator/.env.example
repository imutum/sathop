# ── image（默认指向 imutum 官方镜像；自部署可改为你的 GitHub 用户名或组织名）──
SATHOP_IMAGE=ghcr.io/imutum/sathop
SATHOP_TAG=latest

SATHOP_HOST=0.0.0.0
SATHOP_PORT=8000
SATHOP_DEV=0
SATHOP_DB=./data/orchestrator.db
SATHOP_BUNDLES=./data/bundles
SATHOP_SHARED=./data/shared
SATHOP_TOKEN=change-me-to-a-long-random-string

# Credentials are specified per-batch at creation time (BatchCreate.credentials)
# and ride on each lease — there's no orchestrator-side registry or YAML file.

# Retention sweeper. Set any value to 0 to keep rows forever / disable the loop.
SATHOP_RETAIN_EVENTS_DAYS=30
SATHOP_RETAIN_DELETED_DAYS=7
SATHOP_RETENTION_SWEEP_SEC=3600
